# ============================================================
# GIP MANAGEMENT SYSTEM — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ── Google Apps Script Web App URL ───────────────────────────
# After deploying your Apps Script as a Web App,
# paste the deployment URL here.
# Example: https://script.google.com/macros/s/AKfy.../exec
NEXT_PUBLIC_GAS_URL=

# ── API Secret ────────────────────────────────────────────────
# A shared secret sent in X-API-Secret header.
# Set the SAME value in your Apps Script PropertiesService.
# Generate with: openssl rand -hex 32
NEXT_PUBLIC_API_SECRET=

# ── App Metadata ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="GIP Management System"
NEXT_PUBLIC_PROVINCE="Province of Marinduque"
NEXT_PUBLIC_APP_YEAR="2025"

# ── Admin Login ───────────────────────────────────────────────
# Fallback admin credentials for the Apps Script USERS sheet
# Only used if the USERS sheet is empty
GAS_ADMIN_USERNAME=admin
GAS_ADMIN_PASSWORD=changeme123
